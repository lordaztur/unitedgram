# ======================================================================
#  unitedgram — configuração
#  Copie para .env e preencha. Valores sensíveis (tokens, cookies) NÃO
#  devem ser commitados — o .gitignore já cobre .env.
# ======================================================================


# ======================================================================
#  OBRIGATÓRIAS
# ======================================================================

# --- Site de origem (chat baseado em Laravel + laravel-echo-server) ---

# URL base do site. Sem barra final.
BASE_URL="https://example.com"

# Host do servidor WebSocket (Socket.IO / laravel-echo-server). Sem porta.
# A porta vem de WS_PORT (default 8443, convenção do UNIT3D).
WS_HOST="https://example.com"

# (Opcional) Porta do WebSocket. Default 8443 (convenção UNIT3D).
# Descomente pra usar outra (ex: 6001 em dev local sem proxy).
#WS_PORT=8443

# ID numérico da sala de chat a ouvir. Descubra inspecionando a URL
# do chat no site ou chamadas XHR em /api/chat/rooms.
CHATROOM_ID=1

# ID numérico do seu usuário no site. Usado ao POSTAR mensagens de volta.
# Pegue em /api/auth/me ou no HTML de perfil.
USER_ID=0

# Token CSRF do Laravel (meta tag ou cookie XSRF-TOKEN do site).
# Usado em todos os POSTs e no handshake do canal privado.
CSRF_TOKEN=""

# Cookie HTTP completo da sua sessão. Copie do DevTools do navegador
# logado: Application → Cookies → copie o header "Cookie" inteiro.
# Expira com a sessão; o bot alerta no Telegram quando cair.
COOKIE=""


# --- Telegram ---

# Token do bot (@BotFather → /newbot ou /mybots).
TELEGRAM_BOT_TOKEN=""

# ID do chat/grupo onde o bot espelha. Negativo para grupos/supergrupos.
# Pegue enviando uma msg ao @userinfobot.
TELEGRAM_CHAT_ID=0

# (Opcional) ID do tópico se o chat é um supergrupo com tópicos.
# Deixe comentado para usar o tópico principal.
#TELEGRAM_TOPIC_ID=


# ======================================================================
#  IDENTIDADE / PREFERÊNCIAS (opcionais, mas recomendadas)
# ======================================================================

# Seu username no site. Usado para detectar mensagens próprias
# (mostra "Você" no Telegram e oferece botão de deletar).
MY_USERNAME=""

# Seu handle do Telegram (sem @). Se setado, menções ao seu username/aliases
# no site viram tag ao lado do texto: "fulano [@SeuHandle]".
# Controlado por TAG_ALIASES (padrão ligado).
TELEGRAM_USER=""

# Aliases/apelidos adicionais pelos quais você é chamado no chat.
# Separados por vírgula. São tratados junto com MY_USERNAME para detectar
# menções e identificar suas próprias mensagens.
# Ex: MY_ALIASES="fulano,Fulano2,ciclano,doidao"
MY_ALIASES=""

# (Opcional) API key do imgbb.com para re-hospedar imagens que você envia
# do Telegram pro site. Sem isso, imagens do Telegram não vão pro site.
# Grátis em https://api.imgbb.com/
IMGBB_API_KEY=""


# ======================================================================
#  TUNING (opcionais; defaults são os usados em produção)
# ======================================================================

# --- Startup / backfill ---

# Quantas mensagens recentes entregar no Telegram ao iniciar.
# 0 = nenhuma (só mensagens novas depois do startup).
#BACKFILL_COUNT=10


# --- Timeouts HTTP (segundos) ---

# Client principal (chamadas ao site + auth de canais WS).
#HTTP_TIMEOUT=30

# Client de upload/download externo (imgbb, CDNs de imagem).
#UPLOAD_TIMEOUT=120


# --- Intervalos de tarefas periódicas (segundos) ---

# Log "💓 uptime=..." para saber que o bot está vivo.
#HEARTBEAT_INTERVAL=300

# Check de sessão: se retornar 401/403/419, alerta no Telegram.
#COOKIE_PROBE_INTERVAL=600

# Fallback: quando o WebSocket cai, força um fetch HTTP periódico
# para não perder mensagens enquanto reconecta.
#SAFETY_RECONCILE_INTERVAL=60


# --- Caches em memória ---

# Janela de mapeamento Telegram→site. Maior = mais replies funcionam
# para mensagens antigas; custo: ~1 KB por entrada.
#MSG_MAP_LIMIT=2000

# Janela de deduplicação por site_id. Evita reenvios quando o reconcile
# HTTP + evento WS chegam em ordem confusa.
#QUEUED_DEDUP_LIMIT=1000


# --- Álbum (media_group) ---

# Espera antes de montar o álbum: Telegram entrega fotos do mesmo álbum
# em eventos separados. Subir se álbuns chegam incompletos no site.
#ALBUM_WAIT_SECONDS=4


# --- Reconexão WebSocket ---

# Espera inicial após desconexão (segundos).
#WS_BACKOFF_INITIAL=3

# Teto do backoff exponencial (segundos).
#WS_BACKOFF_MAX=60


# --- Protocolo / headers ---

# User-Agent enviado ao site. Só mexer se o site bloqueia UA padrão.
#USER_AGENT="Mozilla/5.0 BridgeBot/2.0"

# Caminho do endpoint Socket.IO. Raro precisar mudar (laravel-echo-server
# usa /socket.io por default).
#WS_PATH=/socket.io


# --- Features (booleans: true/false, 1/0, yes/no, sim) ---

# Se true, mensagens suas no site ganham botão "🗑️ Deletar" no Telegram
# que apaga em ambos os lados.
#SHOW_DELETE_BUTTON=true

# Se true, menções aos seus aliases no texto viram "apelido [@TELEGRAM_USER]"
# no Telegram (útil pra receber notificação do app).
#TAG_ALIASES=true

# Se true, quando uma mensagem é apagada no site (por qualquer um),
# o bot apaga a cópia no Telegram também. Default é false porque
# inclui deleções por admin/mod, não só pelo autor.
#MIRROR_DELETIONS=false
